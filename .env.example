ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# PORT=3001

# AnkiConnect (Anki must be open with AnkiConnect add-on installed)
# ANKI_URL=http://localhost:8765
# ANKI_COMPANION_DECK=Companion   ← deck for new cards created by the companion

# VoiceVox (optional — provides sentence audio on new/updated Anki cards)
# VOICEVOX_URL=http://localhost:50021
# VOICEVOX_SPEAKER=1              ← speaker ID (1 = Zundamon normal)
